              <div className="text-[#3b82f6] text-xs tracking-[3px] font-medium">THE ARMORY</div>
              <h2 className="text-6xl tracking-[-2.5px] font-semibold mt-1">Shots</h2>
            </div>
            <button 
              onClick={() => setShowShotsModal(true)}
              className="btn btn-ghost px-6 py-2 rounded-full flex items-center gap-2 text-sm"
            >
              See all <ArrowRight className="w-4 h-4" />
            </button>
          </div>

          <div className="shots-grid">
            {SHOTS.slice(0, 8).map((shot) => (
              <div 
                key={shot.id} 
                onClick={() => { setSelectedShot(shot); setShowCreate(true); setWizardStep(2); }}
                className="shot-card cursor-pointer group"
              >
                <img 
                  src={shot.thumbnail} 
                  alt={shot.name} 
                  className="absolute inset-0 w-full h-full object-cover" 
                />
                <div className="absolute bottom-0 left-0 right-0 p-6 z-10 shot-label">
                  <div className="font-semibold text-[21px] tracking-[-0.5px] text-white leading-none mb-1.5">{shot.name}</div>
                  <div className="text-white/70 text-[13.5px] tracking-[-0.1px] line-clamp-1">{shot.description}</div>
                </div>
                <div className="absolute top-4 right-4 px-3.5 py-1 text-[10px] font-medium tracking-[0.5px] rounded-full bg-black/70 text-white/90 backdrop-blur-md border border-white/10">
                  {shot.category}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* ARTISTS IN MOTION */}
      <div className="max-w-6xl mx-auto px-6 py-20">
        <div className="text-center mb-12">
          <div className="text-[#3b82f6] text-xs tracking-[3px]">REAL ARTISTS. REAL CLIPS.</div>
          <h2 className="text-6xl tracking-[-2px] font-semibold mt-2">Artists in motion</h2>
        </div>

        <div className="grid md:grid-cols-3 gap-6">
          {ARTISTS.map((artist, i) => (
            <div key={i} className="card rounded-3xl p-6 flex flex-col">
              <div className="flex items-center gap-4 mb-6">
                <img src={artist.img} alt={artist.name} className="w-14 h-14 rounded-2xl object-cover ring-1 ring-white/10" />
                <div>
                  <div className="font-semibold text-xl">{artist.name}</div>
                  <div className="text-[#a1a1aa] text-sm">{artist.handle}</div>
                </div>
              </div>
              <div className="mt-auto text-sm text-[#a1a1aa]">
                "make-gvids completely changed how I release music. My last clip got 180K views in 4 days."
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* TESTIMONIALS */}
      <div className="bg-[#0a0a10] py-16 border-y border-white/10">
        <div className="max-w-5xl mx-auto px-6">
          <div className="text-center mb-10">
            <div className="text-[#3b82f6] text-xs tracking-[3px]">REAL FEEDBACK, REAL RESULTS</div>
            <h2 className="text-6xl tracking-[-2px] font-semibold mt-1">And they're talking</h2>
          </div>

          <div className="grid md:grid-cols-2 gap-4">
            {TESTIMONIALS.map((quote, idx) => (
              <div key={idx} className="card p-8 rounded-3xl text-[17px] leading-tight border-l-4 border-[#3b82f6]">
                “{quote}”
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* FAQ */}
      <div className="max-w-3xl mx-auto px-6 py-20">
        <div className="text-center mb-10">
          <div className="text-[#a1a1aa] text-xs tracking-widest">COMMON QUESTIONS</div>
          <h2 className="text-5xl tracking-[-1.5px] font-semibold mt-2">FAQ</h2>
        </div>

        <div className="space-y-3">
          {FAQS.map((faq, i) => (
            <details key={i} className="card rounded-2xl p-7 group">
              <summary className="font-semibold text-lg cursor-pointer list-none flex justify-between items-center">
                {faq.q}
                <span className="text-[#555568] group-open:rotate-45 transition">+</span>
              </summary>
              <p className="mt-4 text-[#a1a1aa] leading-relaxed text-[15px]">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>

      {/* Dev toggle removed — new make-gvids Studio is the permanent default experience */}

      {/* FINAL CTA */}
      <div className="border-t border-white/10 py-20 text-center px-6">
        <div className="max-w-xl mx-auto">
          <h2 className="text-6xl tracking-[-2.5px] font-semibold leading-none mb-4">AI is going to be used regardless.<br />Why not make it tasteful?</h2>
          <p className="text-[#a1a1aa] mb-8 text-xl">Create clips as fast as you drop tracks.</p>
          
          <button onClick={() => setShowCreate(true)} className="btn btn-primary bg-[#3b82f6] hover:bg-[#2563eb] border-[#3b82f6] text-white text-base px-12 py-[17px] rounded-full inline-flex items-center gap-3">
            Start creating with SuperGrok <ArrowRight />
          </button>
        </div>
      </div>

      {/* FOOTER */}
      <footer className="border-t border-white/10 py-8 text-center text-[#555568] text-sm">
        make-gvids — A faithful high-fidelity clone of VisualEssential experience, powered directly by SuperGrok via OAuth.<br />
        Built for musicians who want beautiful results, fast.
      </footer>


      {/* OLD WIZARD CODE FULLY REMOVED — new make-gvids Studio is the only creation experience */}

      {/* NEW STUDIO (the only creation UI) */}
      {showCreate && (
        <Studio
          onClose={() => setShowCreate(false)}
          session={session}
          onConnect={handleSuperGrokConnect}
          SHOTS={SHOTS}
          onGenerate={(data) => {
            setGeneratedVideo("PRODUCTION_PENDING");
            (window as any).__GROK_VISUAL_LAST_PROMPT__ = data.prompt;
            setShowCreate(false);
            toast.success("Prompt ready for Grok", { description: "make-gvids Studio" });
          }}
        />
      )}

      {/* HOW IT WORKS MODAL */}
      <AnimatePresence>
        {showHowItWorks && (
          <div className="fixed inset-0 z-[85] flex items-center justify-center bg-black/90 p-6" onClick={() => setShowHowItWorks(false)}>
            <div className="max-w-2xl w-full glass rounded-3xl p-10" onClick={e => e.stopPropagation()}>
              <div className="text-5xl tracking-[-1.5px] font-semibold mb-10">How make-gvids works</div>
              
              <div className="space-y-9 text-[17px]">
                {[
                  ["1. Upload your face", "3–5 high-quality selfies. Different angles = dramatically better consistency."],
                  ["2. Drop your audio", "A clean 8–15 second vocal performance. The AI uses this for perfect lip sync."],
                  ["3. Pick a shot", "Choose from 100+ cinematic, studio, neon and narrative environments built specifically for music."],
                  ["4. Generate with Grok", "make-gvids + Grok 4.3 Video creates the clip. Usually ready in under two minutes."],
                ].map(([title, desc], i) => (
                  <div key={i} className="flex gap-6">
                    <div className="font-mono text-[#3b82f6] text-sm pt-1 w-8 flex-shrink-0">{title.split('.')[0]}</div>
                    <div>
                      <div className="font-medium mb-1">{title.split('. ')[1]}</div>
                      <div className="text-[#a1a1aa] leading-snug">{desc}</div>
                    </div>
                  </div>
                ))}
              </div>

              <button onClick={() => { setShowHowItWorks(false); setShowCreate(true); }} className="btn btn-primary mt-10 w-full py-4 rounded-2xl text-base">Start your first clip</button>
            </div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
}

export default App;
