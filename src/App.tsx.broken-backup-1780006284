    setOauthFlow({ active: false, status: 'idle' });
  };

  const startRealDeviceAuth = async () => {
    setOauthFlow({ active: true, status: 'starting' });

    try {
      const res = await fetch(`${BACKEND}/auth/device/start`, {
        method: 'POST',
      });
      const data = await res.json();

      if (data.demo_fallback || !data.device_code) {
        // Graceful fallback for local dev when client_id is not yet approved
        toast.info('Using demo auth (no real xAI client_id configured yet)');
        updateSession({ connected: true });
        setShowOAuthModal(false);
        setOauthFlow({ active: false, status: 'idle' });
        return;
      }

      setOauthFlow({
        active: true,
        deviceCode: data.device_code,
        userCode: data.user_code,
        verificationUri: data.verification_uri,
        verificationUriComplete: data.verification_uri_complete,
        status: 'waiting',
      });

      // Begin polling the backend
      pollForAuthorization(data.device_code, data.interval || 5);
    } catch (e) {
      console.error(e);
      toast.error('Could not reach make-gvids backend');
      setOauthFlow({ active: false, status: 'error', error: 'Backend unreachable' });
    }
  };

  const pollForAuthorization = async (deviceCode: string, interval: number) => {
    const maxAttempts = 120; // ~10 minutes
    let attempts = 0;

    const tick = async () => {
      attempts++;
      if (attempts > maxAttempts) {
        setOauthFlow((f) => ({ ...f, status: 'error', error: 'Authorization timed out' }));
        return;
      }

      try {
        const res = await fetch(`${BACKEND}/auth/device/status?device_code=${encodeURIComponent(deviceCode)}`);
        const data = await res.json();

        if (data.status === 'authorized' && data.sessionId) {
          // Fetch full session info
          const sessRes = await fetch(`${BACKEND}/auth/session/${data.sessionId}`);
          const sess = await sessRes.json();

          if (sess.connected) {
            updateSession({
              connected: true,
              plan: sess.plan || 'SuperGrok',
              credits: sess.credits || 1842,
            });
            // Persist the real session id for future calls
            localStorage.setItem('makegvids_real_session', data.sessionId);

            setOauthFlow({ active: false, status: 'success' });
            setShowOAuthModal(false);

            toast.success('Connected to SuperGrok', {
              description: 'Real xAI OAuth complete. Your subscription quotas are now active.',
            });
            return;
          }
        }

        if (data.status === 'slow_down') {
          setTimeout(tick, (data.interval || interval + 2) * 1000);
          return;
        }

        if (data.error) {
          setOauthFlow((f) => ({ ...f, status: 'error', error: data.error }));
          return;
        }

        // Still pending
        setOauthFlow((f) => ({ ...f, status: 'authorizing' }));
        setTimeout(tick, interval * 1000);
      } catch (e) {
        // Transient network error — keep trying a bit longer
        setTimeout(tick, interval * 1000);
      }
    };

    // First poll after a short delay
    setTimeout(tick, 2500);
  };

