# make-gvids backend — copy this file to .env
#
# Generation runs behind seams in server/provider.js, routing to provider clients
# in server/providers/{kling,fal}.js. With NO keys set (or MOCK_GENERATION=1) the
# seams return deterministic placeholders so the whole app flows end-to-end.

# Backend
PORT=8787
BACKEND_URL=http://localhost:8787

# Mock mode — force placeholder output for every stage (no API calls).
# Even unset, any stage whose provider key is missing falls back to a placeholder.
MOCK_GENERATION=0

# Kling (API-Key auth) — try-on, images/generations, Avatar
# Base defaults to https://api-singapore.klingai.com
KLING_API_KEY=
# KLING_API_BASE=https://api-singapore.klingai.com

# fal — background removal (rembg, Phase 1 isolate)
FAL_KEY=

# Optional: override the legacy /generate video model label
VIDEO_MODEL=

# Reference-image handling (legacy /generate path)
# Set ENABLE_REFS=1 only if your provider accepts reference images.
ENABLE_REFS=0
MAX_REF_IMAGE_LONG_EDGE=1280
REF_IMAGE_JPEG_QUALITY=88

# Optional Wav2Lip post-processing pass (requires the wav2lip setup in scripts/)
WAV2LIP_ENABLED=0
