# make-gvids backend — copy this file to .env
#
# The video-generation provider is wired in server/provider.js.
# Pick a provider (Replicate, Fal, Runway, Luma, Pika, Kling, ...), implement
# submitGeneration()/pollStatus() there, then set the values below.

# Backend
PORT=8787
BACKEND_URL=http://localhost:8787

# Provider credentials (read by server/provider.js)
VIDEO_API_KEY=
# Optional, provider-specific:
VIDEO_API_BASE=
VIDEO_MODEL=

# Reference-image handling
# Set ENABLE_REFS=1 only if your provider accepts reference images.
ENABLE_REFS=0
MAX_REF_IMAGE_LONG_EDGE=1280
REF_IMAGE_JPEG_QUALITY=88

# Optional Wav2Lip post-processing pass (requires the wav2lip setup in scripts/)
WAV2LIP_ENABLED=0
