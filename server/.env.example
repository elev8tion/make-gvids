# g-vid — Real xAI SuperGrok OAuth (Device Code Flow)
# Copy this file to .env

# xAI OAuth Client ID
# - Required for real OAuth device flow
# - Register an OAuth client at console.x.ai or via xAI support
XAI_CLIENT_ID=b1a00492-073a-47ea-816f-4c329264a828

# Backend port
PORT=8787

# OAuth issuer (device code endpoints)
XAI_OAUTH_ISSUER=https://auth.x.ai
ENABLE_XAI_REFS=0

# When deploying, set VITE_BACKEND_URL/FRONTEND_URL as needed
BACKEND_URL=http://localhost:8787

# Optional future scopes tuning (if you need more than the default scopes):
# XAI_OAUTH_SCOPES="openid profile email api:access offline_access"
